{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "minimax": {
      "name": "MiniMax",
      "npm": "@ai-sdk/anthropic",
      "models": {
        "MiniMax-M2.7": {
          "name": "MiniMax-M2.7",
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 200000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "thinking_config": {
            "mode": "forced_on"
          }
        },
        "MiniMax-M2.7-highspeed": {
          "name": "MiniMax-M2.7-highspeed",
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 200000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "thinking_config": {
            "mode": "forced_on"
          }
        },
        "MiniMax-M3": {
          "name": "MiniMax-M3",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "video"
            ],
            "output": [
              "text"
            ]
          },
          "options": {
            "reasoningSummary": "auto"
          },
          "variants": {
            "none-thinking": {
              "thinking": {
                "type": "disabled"
              }
            },
            "thinking": {
              "thinking": {
                "type": "adaptive"
              }
            }
          },
          "thinking_config": {
            "mode": "switchable",
            "default_value": "false"
          }
        }
      },
      "whitelist": [
        "MiniMax-M2.7-highspeed",
        "MiniMax-M2.7",
        "MiniMax-M3"
      ],
      "options": {
        "apiKey": "sk-xxx",
        "baseURL": "https://agent.minimaxi.com/mavis/api/v1/llm/v1"
      }
    }
  },
  "permission": {
    "*": "allow",
    "question": "deny"
  },
  "skills": {
    "paths": [
      "/Users/ruochen.yin/.mavis/skills",
      "/Users/ruochen.yin/.mavis/.builtin-skills"
    ]
  },
  "plugin": [
    "mavis"
  ]
}
